# Secretos y variables de entorno - NUNCA se suben al repositorio
.env
.env.*
!.env.example

# Configuracion local de Claude Code (no se comparte)
.claude/settings.local.json

# Registro de prompts en bruto: puede contener texto pegado sin filtrar
# (incluidos secretos). Se mantiene en local, no se versiona.
prompts-log.md

# Artefactos de Python
__pycache__/
*.pyc
.pytest_cache/
.venv/

# Modelo entrenado (se entrega aparte; puede ser grande)
servicio-ia/modelo/*.pkl
!servicio-ia/modelo/clasificador.pkl

# Archivos de datos y embeddings (pesados)
*.csv
*.npy
ml/*.csv
ml/*.npy

# Resultados locales (gráficas y logs de entrenamiento)
ml/results/

# Supabase temp
supabase/.temp/

.vercel

# Documentación de la memoria del TFG (local)
memoria/
