# === Variables de entorno — TFG plataforma de gestión documental ===
# Copia este fichero a .env y rellena los valores. .env NO se versiona.

# --- Supabase: Management API / CLI (uso del equipo de desarrollo) ---
SUPABASE_ACCESS_TOKEN=

# --- Supabase: conexión del proyecto (uso de la aplicación) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Servicio de IA (extracción de texto + clasificación) ---
SERVICIO_IA_URL=http://localhost:8000
